DATABASE_URL=postgresql://user:password@localhost:5432/campnav
JWT_SECRET=replace_with_a_long_random_string_minimum_32_chars
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
DEMO_ADMIN_EMAIL=admin@campnav.local
DEMO_ADMIN_PASSWORD=ChangeMe123!

# Africa's Talking USSD Integration
# 1. Sign up at https://africastalking.com and create an app
# 2. Go to Settings > API Key to get your key
# 3. Sandbox username is always "sandbox" for testing
# 4. Set USSD callback URL to: https://<your-ngrok-or-deploy-url>/api/ussd/webhook
# 5. Test via the AT Simulator: https://simulator.africastalking.com
AT_API_KEY=your_africa_talking_api_key
AT_USERNAME=sandbox
