{
  "name": "CampNav - Offline Navigation",
  "short_name": "CampNav",
  "description": "Offline-first navigation and logistics coordination for large-scale gatherings",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait",
  "theme_color": "#0D1B4B",
  "background_color": "#FFFFFF",
  "categories": ["navigation", "utilities"],
  "screenshots": [
    {
      "src": "/screenshots/screenshot-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/screenshots/screenshot-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-maskable-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Open Map",
      "short_name": "Map",
      "description": "View the main navigation map",
      "url": "/app?mode=map",
      "icons": [
        {
          "src": "/shortcuts/map-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Report Lost Person",
      "short_name": "Report",
      "description": "Submit a lost person report",
      "url": "/app/report",
      "icons": [
        {
          "src": "/shortcuts/report-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Emergency Contacts",
      "short_name": "Emergency",
      "description": "View emergency contact numbers",
      "url": "/app/emergency",
      "icons": [
        {
          "src": "/shortcuts/emergency-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": ["image/*", "video/*"]
        }
      ]
    }
  }
}
